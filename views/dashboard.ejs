<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - Ferreteria Kauquenes</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/header') %>

  <main class="container">
    <h1>Bienvenido, <%= usuario.nombre %></h1>

    <div class="cards">
      <div class="card">
        <div class="card-icon">📦</div>
        <h3>Productos</h3>
        <p class="card-number"><%= totalProductos %></p>
        <small>en inventario</small>
      </div>
      <div class="card">
        <div class="card-icon">📂</div>
        <h3>Categorias</h3>
        <p class="card-number"><%= totalCategorias %></p>
        <small>registradas</small>
      </div>
    </div>

    <footer>Ferreteria Kauquenes &copy; <%= new Date().getFullYear() %></footer>
  </main>
</body>
</html>
