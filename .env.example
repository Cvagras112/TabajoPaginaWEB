# Proyecto Ferreteria - Variables de entorno
# Copia este archivo como .env y completa los valores

# URL de conexion a MySQL (usada por Sequelize para desarrollo y produccion)
DATABASE_URL=mysql://root:@127.0.0.1:3306/ferreteria_dev

# Base de datos (por partes, opcional)
DB_NAME=ferreteria_dev
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1

# Puerto donde corre la aplicacion
PORT=3000

# Entorno: development, test o production
NODE_ENV=development

# Clave secreta para firmar tokens JWT (cambiar en produccion)
JWT_SECRET=cambia_esto_por_una_clave_segura

# URL del frontend permitido por CORS
CORS_ORIGIN=http://localhost:5173
