<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nueva Cotizacion - Ferreteria Kauquenes</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/header') %>

  <main class="container" style="max-width:600px">
    <a href="/cotizaciones" style="color:#1a56db;text-decoration:none;font-size:0.9em">&larr; Volver</a>
    <h1 style="margin-top:8px">Nueva Cotizacion</h1>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <div class="card">
      <form action="/cotizaciones" method="POST">
        <div class="form-group">
          <label for="cliente_nombre">Nombre del cliente</label>
          <input type="text" id="cliente_nombre" name="cliente_nombre" required autofocus>
        </div>

        <div class="form-group">
          <label for="filtro_categoria">Filtrar por categoria</label>
          <select id="filtro_categoria" style="width:100%;padding:12px;border:2px solid #dfe6e9;border-radius:8px;font-size:0.95em" onchange="filtrarProductos()">
            <option value="">Todas las categorias</option>
            <% categorias.forEach(c => { %>
              <option value="<%= c.id %>"><%= c.nombre %></option>
            <% }) %>
          </select>
        </div>

        <div class="form-group">
          <label for="producto_id">Producto</label>
          <select id="producto_id" name="producto_id" required style="width:100%;padding:12px;border:2px solid #dfe6e9;border-radius:8px;font-size:0.95em">
            <option value="">Selecciona un producto</option>
            <% productos.forEach(p => { %>
              <option value="<%= p.id %>" data-categoria="<%= p.categoria_id || '' %>"><%= p.nombre %> - $<%= parseFloat(p.precio).toFixed(2) %> (stock: <%= p.stock %>)</option>
            <% }) %>
          </select>
        </div>

        <div class="form-group">
          <label for="cantidad">Cantidad</label>
          <input type="number" id="cantidad" name="cantidad" min="1" value="1" required>
        </div>

        <button type="submit" class="btn btn-primary">Crear cotizacion</button>
      </form>
    </div>
  </main>

  <script>
    function filtrarProductos() {
      var catId = document.getElementById('filtro_categoria').value;
      var select = document.getElementById('producto_id');
      var options = select.options;
      for (var i = 0; i < options.length; i++) {
        var opt = options[i];
        if (!opt.value) { opt.style.display = ''; continue; }
        var cat = opt.getAttribute('data-categoria');
        opt.style.display = (!catId || cat === catId) ? '' : 'none';
      }
      select.value = '';
    }
  </script>
</body>
</html>
