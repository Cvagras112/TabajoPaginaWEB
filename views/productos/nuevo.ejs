<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nuevo Producto - Ferreteria Kauquenes</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/header') %>

  <main class="container" style="max-width:600px">
    <a href="/productos" style="color:#1a56db;text-decoration:none;font-size:0.9em">&larr; Volver</a>
    <h1 style="margin-top:8px">Nuevo Producto</h1>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <div class="card">
      <form action="/productos" method="POST">
        <div class="form-group">
          <label for="nombre">Nombre del producto</label>
          <input type="text" id="nombre" name="nombre" required autofocus>
        </div>
        <div class="form-group">
          <label for="tipo">Tipo / Medida (ej: pulgada 1/2, mm 10, metro)</label>
          <input type="text" id="tipo" name="tipo" placeholder="pulgada 1/2">
        </div>
        <div class="form-group">
          <label for="gtin">Codigo GTIN / EAN</label>
          <input type="text" id="gtin" name="gtin" placeholder="7801234567890">
        </div>
        <div class="form-group">
          <label for="precio">Precio</label>
          <input type="number" id="precio" name="precio" step="0.01" min="0" value="0" required>
        </div>
        <div class="form-group">
          <label for="stock">Stock inicial</label>
          <input type="number" id="stock" name="stock" min="0" value="0" required>
        </div>
        <div class="form-group">
          <label for="disponibilidad">Disponibilidad</label>
          <select name="disponibilidad" id="disponibilidad" style="width:100%;padding:12px;border:2px solid #dfe6e9;border-radius:8px;font-size:0.95em">
            <option value="1">Disponible</option>
            <option value="0">No disponible</option>
          </select>
        </div>
        <button type="submit" class="btn btn-primary">Registrar producto</button>
      </form>
    </div>
  </main>
</body>
</html>
