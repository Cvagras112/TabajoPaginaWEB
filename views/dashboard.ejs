<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - Ferreteria Kauquenes</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/header') %>

  <main class="container">
    <h1>Bienvenido, <%= usuario.nombre %></h1>

    <div class="cards">
      <a href="/inventario" class="card dashboard-card">
        <div class="card-icon">📊</div>
        <h3>Inventario</h3>
        <p class="card-number"><%= totalProductos %></p>
        <small>productos en sistema</small>
      </a>
      <a href="/productos?stock_bajo=1" class="card dashboard-card">
        <div class="card-icon">⚠️</div>
        <h3>Stock Bajo</h3>
        <p class="card-number"><%= stockBajo %></p>
        <small>por debajo de 10</small>
      </a>
      <a href="/cotizaciones" class="card dashboard-card">
        <div class="card-icon">📋</div>
        <h3>Cotizaciones</h3>
        <p class="card-number"><%= pendientes %></p>
        <small>pendientes</small>
      </a>
      <a href="/categorias" class="card dashboard-card">
        <div class="card-icon">📂</div>
        <h3>Categorias</h3>
        <p class="card-number"><%= totalCategorias %></p>
        <small>registradas</small>
      </a>
    </div>

    <footer>Ferreteria Kauquenes &copy; <%= new Date().getFullYear() %></footer>
  </main>
</body>
</html>
