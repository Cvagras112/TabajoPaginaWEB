<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Productos - Ferreteria Kauquenes</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/header') %>

  <main class="container">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
      <h1 style="margin:0">Productos</h1>
      <% if (esAdmin) { %>
        <a href="/productos/nuevo" class="btn btn-primary" style="width:auto">+ Nuevo</a>
      <% } %>
    </div>

    <div class="card" style="margin-bottom:20px;padding:16px 20px">
      <form action="/productos" method="GET" style="display:flex;gap:10px;flex-wrap:wrap;align-items:end">
        <div style="flex:1;min-width:180px">
          <label style="display:block;font-size:0.8em;font-weight:600;margin-bottom:4px;color:#636e72">Buscar</label>
          <input type="text" name="buscar" value="<%= filtros.buscar %>" placeholder="Nombre del producto..." style="width:100%;padding:8px 12px;border:2px solid #dfe6e9;border-radius:6px;font-size:0.9em">
        </div>
        <div style="min-width:160px">
          <label style="display:block;font-size:0.8em;font-weight:600;margin-bottom:4px;color:#636e72">Categoria</label>
          <select name="categoria_id" style="width:100%;padding:8px 12px;border:2px solid #dfe6e9;border-radius:6px;font-size:0.9em;background:white">
            <option value="">Todas</option>
            <% categorias.forEach(c => { %>
              <option value="<%= c.id %>" <%= filtros.categoria_id == c.id ? 'selected' : '' %>><%= c.nombre %></option>
            <% }) %>
          </select>
        </div>
        <div style="min-width:120px">
          <label style="display:block;font-size:0.8em;font-weight:600;margin-bottom:4px;color:#636e72">&nbsp;</label>
          <label style="display:flex;align-items:center;gap:6px;cursor:pointer;padding:8px 0;font-size:0.9em">
            <input type="checkbox" name="stock_bajo" value="1" <%= filtros.stock_bajo === '1' ? 'checked' : '' %> onchange="this.form.submit()">
            Stock bajo (<10)
          </label>
        </div>
        <div style="display:flex;gap:6px">
          <label style="display:block;font-size:0.8em;font-weight:600;margin-bottom:4px;color:#636e72">&nbsp;</label>
          <button type="submit" class="btn btn-primary" style="width:auto;padding:8px 16px;font-size:0.85em">Filtrar</button>
          <a href="/productos" class="btn btn-primary" style="width:auto;padding:8px 16px;font-size:0.85em;background:transparent;border:1px solid #ccc;color:#636e72;text-decoration:none">Limpiar</a>
        </div>
      </form>
    </div>

    <% if (productos.length === 0) { %>
      <div class="card" style="text-align:center;padding:40px">
        <p style="font-size:3rem">📦</p>
        <p style="color:#999">No se encontraron productos</p>
      </div>
    <% } else { %>
      <div class="card" style="padding:0;overflow:hidden">
        <table>
          <thead>
            <tr style="background:#f8f9fa;text-align:left">
              <th style="padding:12px 16px;font-size:0.85em">Nombre</th>
              <th style="padding:12px 16px;font-size:0.85em">Tipo/Medida</th>
              <th style="padding:12px 16px;font-size:0.85em">Categoria</th>
              <th style="padding:12px 16px;font-size:0.85em">GTIN</th>
              <th style="padding:12px 16px;font-size:0.85em">Precio</th>
              <th style="padding:12px 16px;font-size:0.85em">Stock</th>
              <th style="padding:12px 16px;font-size:0.85em">Disp.</th>
              <% if (esAdmin) { %><th style="padding:12px 16px;font-size:0.85em">Accion</th><% } %>
            </tr>
          </thead>
          <tbody>
            <% productos.forEach(p => { %>
              <tr style="border-top:1px solid #edf2f7">
                <td style="padding:12px 16px"><a href="/productos/<%= p.id %>" style="color:#1a56db;text-decoration:none;font-weight:500"><%= p.nombre %></a></td>
                <td style="padding:12px 16px;color:#636e72"><%= p.tipo || '-' %></td>
                <td style="padding:12px 16px"><%= p.categoria ? p.categoria.nombre : '-' %></td>
                <td style="padding:12px 16px;color:#636e72;font-size:0.85em"><%= p.gtin || '-' %></td>
                <td style="padding:12px 16px;font-weight:600">$<%= parseFloat(p.precio).toFixed(2) %></td>
                <td style="padding:12px 16px"><%= p.stock %></td>
                <td style="padding:12px 16px"><span class="badge <%= p.disponibilidad ? 'badge-aprobada' : 'badge-rechazada' %>"><%= p.disponibilidad ? 'Si' : 'No' %></span></td>
                <% if (esAdmin) { %>
                  <td style="padding:12px 16px;display:flex;gap:8px">
                    <a href="/productos/<%= p.id %>/editar" style="color:#1a56db;font-size:0.85em">Editar</a>
                    <form action="/productos/<%= p.id %>/eliminar" method="POST" onsubmit="return confirm('Eliminar este producto?')" style="display:inline">
                      <button type="submit" style="background:none;border:none;color:#ef4444;font-size:0.85em;cursor:pointer;padding:0">Eliminar</button>
                    </form>
                  </td>
                <% } %>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </main>
</body>
</html>
