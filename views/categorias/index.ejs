<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Categorias - Ferreteria Kauquenes</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/header') %>

  <main class="container">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px">
      <h1 style="margin:0">Categorias</h1>
      <% if (esAdmin) { %>
        <a href="/categorias/nueva" class="btn btn-primary" style="width:auto">+ Nueva</a>
      <% } %>
    </div>

    <% if (categorias.length === 0) { %>
      <div class="card" style="text-align:center;padding:40px">
        <p style="font-size:3rem">📂</p>
        <p style="color:#999">No hay categorias</p>
      </div>
    <% } else { %>
      <div class="card" style="padding:0;overflow:hidden">
        <table>
          <thead>
            <tr style="background:#f8f9fa;text-align:left">
              <th style="padding:12px 16px;font-size:0.85em">Nombre</th>
              <th style="padding:12px 16px;font-size:0.85em">Descripcion</th>
              <% if (esAdmin) { %><th style="padding:12px 16px;font-size:0.85em">Accion</th><% } %>
            </tr>
          </thead>
          <tbody>
            <% categorias.forEach(c => { %>
              <tr style="border-top:1px solid #edf2f7">
                <td style="padding:12px 16px;font-weight:500"><%= c.nombre %></td>
                <td style="padding:12px 16px;color:#636e72;font-size:0.9em"><%= c.descripcion || '-' %></td>
                <% if (esAdmin) { %>
                  <td style="padding:12px 16px;display:flex;gap:8px">
                    <a href="/categorias/<%= c.id %>/editar" style="color:#1a56db;font-size:0.85em">Editar</a>
                    <form action="/categorias/<%= c.id %>/eliminar" method="POST" onsubmit="return confirm('Eliminar esta categoria?')" style="display:inline">
                      <button type="submit" style="background:none;border:none;color:#ef4444;font-size:0.85em;cursor:pointer;padding:0">Eliminar</button>
                    </form>
                  </td>
                <% } %>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </main>
</body>
</html>
