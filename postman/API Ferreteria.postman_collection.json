{
  "info": {
    "name": "API Ferreteria",
    "description": "Coleccion de endpoints para Ferreteria de las ferreterias\n\nFlujo:\n1. Login (POST) -> guarda cookie JWT\n2. Usar demas endpoints -> cookie se reutiliza\n\nVariables:\n{{base_url}} = http://localhost:3000",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Ver login form",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "email", "value": "admin@ferreteria.com", "type": "text" },
                { "key": "password", "value": "admin123", "type": "text" }
              ]
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/auth/logout", "host": ["{{base_url}}"], "path": ["auth", "logout"] }
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Ver dashboard",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/", "host": ["{{base_url}}"], "path": [""] },
            "description": "Dashboard protegido. Requiere login previo."
          }
        }
      ]
    },
    {
      "name": "Cotizaciones",
      "item": [
        {
          "name": "Listar cotizaciones",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/cotizaciones", "host": ["{{base_url}}"], "path": ["cotizaciones"] },
            "description": "Lista todas las cotizaciones (requiere login)"
          }
        },
        {
          "name": "Form nueva cotizacion",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/cotizaciones/nueva", "host": ["{{base_url}}"], "path": ["cotizaciones", "nueva"] }
          }
        },
        {
          "name": "Crear cotizacion",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "cliente_nombre", "value": "Juan Perez", "type": "text" },
                { "key": "producto_id", "value": "1", "type": "text" },
                { "key": "cantidad", "value": "3", "type": "text" }
              ]
            },
            "url": { "raw": "{{base_url}}/cotizaciones", "host": ["{{base_url}}"], "path": ["cotizaciones"] },
            "description": "Crea cotizacion con 1 producto. Si stock insuficiente, devuelve 409."
          }
        },
        {
          "name": "Ver detalle cotizacion",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/cotizaciones/1", "host": ["{{base_url}}"], "path": ["cotizaciones", "1"] },
            "description": "Muestra detalle de cotizacion con todos sus productos"
          }
        },
        {
          "name": "Agregar producto a cotizacion",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "producto_id", "value": "2", "type": "text" },
                { "key": "cantidad", "value": "5", "type": "text" }
              ]
            },
            "url": { "raw": "{{base_url}}/cotizaciones/1/agregar", "host": ["{{base_url}}"], "path": ["cotizaciones", "1", "agregar"] },
            "description": "Agrega un producto a una cotizacion existente. Valida stock (409 si excede)."
          }
        },
        {
          "name": "Cambiar estado (aprobar/rechazar)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "estado", "value": "aprobada", "type": "text" }
              ]
            },
            "url": { "raw": "{{base_url}}/cotizaciones/1/estado", "host": ["{{base_url}}"], "path": ["cotizaciones", "1", "estado"] },
            "description": "Cambia el estado a 'aprobada' o 'rechazada'. Al aprobar descuenta stock. Si stock insuficiente: 409."
          }
        }
      ]
    },
    {
      "name": "rq-05 Tests de stock",
      "item": [
        {
          "name": "TEST: Exceder stock (espera 409)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "cliente_nombre", "value": "Test Stock", "type": "text" },
                { "key": "producto_id", "value": "6", "type": "text" },
                { "key": "cantidad", "value": "999", "type": "text" }
              ]
            },
            "url": { "raw": "{{base_url}}/cotizaciones", "host": ["{{base_url}}"], "path": ["cotizaciones"] },
            "description": "Taladro tiene stock=8. Pedir 999 debe devolver 409 con mensaje de error."
          }
        },
        {
          "name": "TEST: Compra valida (espera 302)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "cliente_nombre", "value": "Compra Valida", "type": "text" },
                { "key": "producto_id", "value": "1", "type": "text" },
                { "key": "cantidad", "value": "2", "type": "text" }
              ]
            },
            "url": { "raw": "{{base_url}}/cotizaciones", "host": ["{{base_url}}"], "path": ["cotizaciones"] },
            "description": "Martillo tiene stock=45. Pedir 2 debe devolver 302 (creado)."
          }
        }
      ]
    }
  ]
}
